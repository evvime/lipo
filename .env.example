# =====================================================================
# Wellnur — Environment Variables
# =====================================================================
# Bu dosya örnek/şablondur. Gerçek değerleri için .env oluşturun.
# .env dosyası asla commit edilmemelidir (.gitignore'da listelidir).
# =====================================================================

# -------------------------------
# Supabase (zorunlu)
# -------------------------------
# Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# -------------------------------
# Feature Flags
# -------------------------------
# Sanal POS (Iyzico) entegrasyonu. Edge Function deploy edilmeden ve
# Iyzico secret'ları set edilmeden true yapmayın.
VITE_ENABLE_VIRTUAL_POS=false

# -------------------------------
# EmailJS — Sipariş onay e-postası
# -------------------------------
# https://www.emailjs.com → Service ID, Template ID ve Public Key
# Template'te kullanılan değişkenler: to_email, to_name, order_id,
# order_short_id, order_date, payment_method, total_amount,
# shipping_address, phone, items_list, language
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_ORDER_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# -------------------------------
# Sentry (opsiyonel) — production hata izleme
# -------------------------------
# https://sentry.io → React projesi oluştur, DSN'i kopyala
VITE_SENTRY_DSN=

# -------------------------------
# Edge Function Secrets (Supabase tarafında set edilir)
# -------------------------------
# supabase secrets set IYZICO_API_KEY=...
# supabase secrets set IYZICO_SECRET_KEY=...
# supabase secrets set IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# supabase secrets set APP_BASE_URL=https://wellnur.com
